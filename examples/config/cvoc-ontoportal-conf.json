[{
    "field-name": "keyword",
    "term-uri-field": "keywordTermURL",
    "cvoc-url": "https://data.agroportal.eu/",
    "js-url": "https://raw.githubusercontent.com/gdcc/dataverse-external-vocab-support/main/scripts/ontoportal.js",
    "headers": {"Authorization": "apikey token=<your_apikey>"},
    "protocol": "ontoportal",
    "retrieval-uri": "https://data.agroportal.eu/ontologies/{encodeUrl:keywordVocabulary}/classes/{encodeUrl:keywordTermURL}?lang=en,fr",
    "term-parent-uri": "",
    "allow-free-text": true,
    "languages":"en,fr",
    "vocabs": {
        "INRAETHES": {
            "vocabularyUri": "https://data.agroportal.eu/ontologies/INRAETHES",
            "uriSpace": "http://opendata.inrae.fr/thesaurusINRAE/"
        },
        "ANAEETHES": {
            "vocabularyUri": "https://data.agroportal.eu/ontologies/ANAEETHES",
            "uriSpace": "http://opendata.inra.fr/anaeeThes/"
        },
        "AGROVOC": {
            "vocabularyUri": "https://data.agroportal.eu/ontologies/AGROVOC",
            "uriSpace": "http://aims.fao.org/aos/agrovoc/"
        },
        "NCBITAXON": {
            "vocabularyUri": "https://data.agroportal.eu/ontologies/NCBITAXON",
            "uriSpace": "http://purl.bioontology.org/ontology/NCBITAXON/"
        },
        "TRANSFORMON": {
            "vocabularyUri": "https://data.agroportal.eu/ontologies/TRANSFORMON",
            "uriSpace": "http://opendata.inrae.fr/PO2/Ontology/TransformON/"
        },
        "FAKE1": {
            "vocabularyUri": "https://data.agroportal.eu/ontologies/FAKE1",
            "uriSpace": "http://www.ebi.ac.uk/efo/"
        }
    },
    "managed-fields": {
        "vocabularyName": "keywordVocabulary",
        "termName": "keywordValue",
        "vocabularyUri": "keywordVocabularyURI"
    },
    "retrieval-filtering": {
        "@context": {
            "termName": "https://schema.org/name",
            "vocabularyName": "https://dataverse.org/schema/vocabularyName",
            "vocabularyUri": "https://dataverse.org/schema/vocabularyUri",
            "lang": "@language",
            "value": "@value"
        },
        "@id": {
            "pattern": "{0}",
            "params": ["@id"]
        },
        "termName": {
            "pattern": "{0}",
            "params": ["/prefLabel"],
            "indexIn": "keywordValue"
        },
        "vocabularyUri": {
            "pattern": "{0}",
            "params": ["/links/ontology"]
        },
        "synonyms": {
            "pattern": "{0}",
            "params": ["/synonym"],
            "indexIn": "keywordValue"
        }
    }
}]
